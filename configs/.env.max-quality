# ══════════════════════════════════════════════════════════════
#  🏆  Max Quality — Maximum quality mode
#  Maximize debate depth. Longer replies, more context, more rounds.
#  Good for: formal reports, deep analysis, high-stakes decisions
# ══════════════════════════════════════════════════════════════

# --- API Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints (optional, leave blank to use official defaults) ---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- Model Selection ---
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=2048      # Long replies for complete arguments
MODEL_TEMPERATURE=0.7             # Standard creativity
MODEL_CALL_RETRIES=3
MODEL_BACKOFF_BASE=2

# --- Debate Settings ---
DEBATE_DEFAULT_ROUNDS=5           # 5-round deep debate
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=24000    # Retain large history
DEBATE_OPENING_DIGEST_CHARS=400
DEBATE_SUMMARY_DIGEST_CHARS=300
DEBATE_FULL_DETAIL_ROUNDS=3       # Last 3 rounds shown in full
CHAIR_SUMMARY_SUP_CHARS=1200
CHAIR_SUMMARY_OPP_CHARS=1200
CHAIR_SUMMARY_SPECIALIST_CHARS=800
CHAIR_SUMMARY_DIGEST_CHARS=300

# --- Output ---
DEBATE_FILENAME_TOPIC_CHARS=30
