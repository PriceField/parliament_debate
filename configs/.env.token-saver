# ══════════════════════════════════════════════════════════════
#  🪙  Token-Saver — Minimal token usage mode
#  Minimize API cost. Shorter replies, less context, fewer rounds.
#  Good for: testing pipelines, budget-constrained runs, quick validation
# ══════════════════════════════════════════════════════════════

# --- API Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints (optional, leave blank to use official defaults) ---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- Model Selection ---
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=512       # Short replies to save tokens
MODEL_TEMPERATURE=0.5             # More focused, less verbose
MODEL_CALL_RETRIES=2              # Fewer retries to save time
MODEL_BACKOFF_BASE=2

# --- Debate Settings ---
DEBATE_DEFAULT_ROUNDS=2           # Only 2 rounds
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=6000     # Heavily reduced history
DEBATE_OPENING_DIGEST_CHARS=100
DEBATE_SUMMARY_DIGEST_CHARS=80
DEBATE_FULL_DETAIL_ROUNDS=1       # Only keep latest 1 round in full
CHAIR_SUMMARY_SUP_CHARS=300
CHAIR_SUMMARY_OPP_CHARS=300
CHAIR_SUMMARY_SPECIALIST_CHARS=200
CHAIR_SUMMARY_DIGEST_CHARS=80

# --- Output ---
DEBATE_FILENAME_TOPIC_CHARS=30
