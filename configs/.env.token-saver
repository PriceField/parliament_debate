# ══════════════════════════════════════════════════════════════
#  🪙  Token-Saver — 省 token 模式
#  Minimize API cost. Shorter replies, less context, fewer rounds.
#  適合：測試流程、預算有限、快速驗證想法
# ══════════════════════════════════════════════════════════════

# --- API Keys（必填 / Required）---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints（選填 / Optional，留空使用官方預設）---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- 模型選擇 / Model Selection ---
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- 模型行為 / Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=512       # 短回覆，省 token
MODEL_TEMPERATURE=0.5             # 較收斂，減少廢話
MODEL_CALL_RETRIES=2              # 少重試，省時間
MODEL_BACKOFF_BASE=2

# --- 辯論設定 / Debate Settings ---
DEBATE_DEFAULT_ROUNDS=2           # 只跑 2 輪
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- 上下文截斷 / Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=6000     # 大幅縮減歷史
DEBATE_OPENING_DIGEST_CHARS=100
DEBATE_SUMMARY_DIGEST_CHARS=80
DEBATE_FULL_DETAIL_ROUNDS=1       # 只保留最新 1 輪全文
CHAIR_SUMMARY_SUP_CHARS=300
CHAIR_SUMMARY_OPP_CHARS=300
CHAIR_SUMMARY_SPECIALIST_CHARS=200
CHAIR_SUMMARY_DIGEST_CHARS=80

# --- 輸出 / Output ---
DEBATE_FILENAME_TOPIC_CHARS=30
