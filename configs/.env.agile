# ══════════════════════════════════════════════════════════════
#  ⚡  Agile — 機動快速模式
#  Fast iteration. Good for testing prompts and debugging.
#  適合：開發測試、prompt 調整、快速迭代
# ══════════════════════════════════════════════════════════════

# --- API Keys（必填 / Required）---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints（選填 / Optional，留空使用官方預設）---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- 模型選擇 / Model Selection ---
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- 模型行為 / Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=768       # 中等長度
MODEL_TEMPERATURE=0.8             # 稍高創意，多樣觀點
MODEL_CALL_RETRIES=2              # 快速失敗
MODEL_BACKOFF_BASE=1              # 最短重試間隔

# --- 辯論設定 / Debate Settings ---
DEBATE_DEFAULT_ROUNDS=2           # 快速完成
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- 上下文截斷 / Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=8000
DEBATE_OPENING_DIGEST_CHARS=150
DEBATE_SUMMARY_DIGEST_CHARS=100
DEBATE_FULL_DETAIL_ROUNDS=1
CHAIR_SUMMARY_SUP_CHARS=400
CHAIR_SUMMARY_OPP_CHARS=400
CHAIR_SUMMARY_SPECIALIST_CHARS=300
CHAIR_SUMMARY_DIGEST_CHARS=100

# --- 輸出 / Output ---
DEBATE_FILENAME_TOPIC_CHARS=30
