# ══════════════════════════════════════════════════════════════
#  ⚡  Agile — Fast iteration mode
#  Fast iteration. Good for testing prompts and debugging.
#  Good for: development testing, prompt tuning, quick iteration
# ══════════════════════════════════════════════════════════════

# --- API Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints (optional, leave blank to use official defaults) ---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- Model Selection ---
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=768       # Medium length
MODEL_TEMPERATURE=0.8             # Slightly higher creativity for diverse viewpoints
MODEL_CALL_RETRIES=2              # Fail fast
MODEL_BACKOFF_BASE=1              # Shortest retry interval

# --- Debate Settings ---
DEBATE_DEFAULT_ROUNDS=2           # Quick completion
DEBATE_INTERACTIVE=true           # Ask to continue after planned rounds
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=8000
DEBATE_OPENING_DIGEST_CHARS=150
DEBATE_SUMMARY_DIGEST_CHARS=100
DEBATE_FULL_DETAIL_ROUNDS=1
CHAIR_SUMMARY_SUP_CHARS=400
CHAIR_SUMMARY_OPP_CHARS=400
CHAIR_SUMMARY_SPECIALIST_CHARS=300
CHAIR_SUMMARY_DIGEST_CHARS=100

# --- Output ---
DEBATE_FILENAME_TOPIC_CHARS=30
