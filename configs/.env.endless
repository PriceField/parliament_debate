# ══════════════════════════════════════════════════════════════
#  ♾️  Endless — Extended debate mode
#  Extended debates with many rounds. Context is compressed
#  aggressively to avoid token overflow on long sessions.
#  Good for: exploring complex topics, academic discussions, marathon debates
# ══════════════════════════════════════════════════════════════

# --- API Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints (optional, leave blank to use official defaults) ---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- Model Selection ---
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=1024      # Standard length
MODEL_TEMPERATURE=0.6             # Slightly lower to avoid drift in long debates
MODEL_CALL_RETRIES=5              # More retries for stability
MODEL_BACKOFF_BASE=3              # Longer backoff to avoid rate limits

# --- Debate Settings ---
DEBATE_DEFAULT_ROUNDS=20          # 20-round deep debate
DEBATE_INTERACTIVE=false          # Run all 20 rounds without pausing (use Ctrl+C to stop early)
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=8000     # Aggressive compression to avoid context overflow
DEBATE_OPENING_DIGEST_CHARS=100
DEBATE_SUMMARY_DIGEST_CHARS=100
DEBATE_FULL_DETAIL_ROUNDS=1       # Only keep latest 1 round in full
CHAIR_SUMMARY_SUP_CHARS=400
CHAIR_SUMMARY_OPP_CHARS=400
CHAIR_SUMMARY_SPECIALIST_CHARS=300
CHAIR_SUMMARY_DIGEST_CHARS=100

# --- Output ---
DEBATE_FILENAME_TOPIC_CHARS=30
