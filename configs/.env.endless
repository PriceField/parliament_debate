# ══════════════════════════════════════════════════════════════
#  ♾️  Endless — 無盡辯論模式
#  Extended debates with many rounds. Context is compressed
#  aggressively to avoid token overflow on long sessions.
#  適合：探索複雜議題、學術研討、馬拉松辯論
# ══════════════════════════════════════════════════════════════

# --- API Keys（必填 / Required）---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints（選填 / Optional，留空使用官方預設）---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- 模型選擇 / Model Selection ---
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- 模型行為 / Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=1024      # 標準長度
MODEL_TEMPERATURE=0.6             # 稍低，避免長辯論中發散
MODEL_CALL_RETRIES=5              # 多重試，確保穩定
MODEL_BACKOFF_BASE=3              # 較長間隔，避免 rate limit

# --- 辯論設定 / Debate Settings ---
DEBATE_DEFAULT_ROUNDS=20          # 20 輪深度辯論
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- 上下文截斷 / Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=8000     # 控制 context 避免爆掉
DEBATE_OPENING_DIGEST_CHARS=100
DEBATE_SUMMARY_DIGEST_CHARS=100
DEBATE_FULL_DETAIL_ROUNDS=1       # 只保留最新 1 輪全文
CHAIR_SUMMARY_SUP_CHARS=400
CHAIR_SUMMARY_OPP_CHARS=400
CHAIR_SUMMARY_SPECIALIST_CHARS=300
CHAIR_SUMMARY_DIGEST_CHARS=100

# --- 輸出 / Output ---
DEBATE_FILENAME_TOPIC_CHARS=30
