# ══════════════════════════════════════════════════════════════
#  Default — Standard balanced configuration
#  Same as built-in defaults. Good for first-time use.
# ══════════════════════════════════════════════════════════════

# --- API Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints (optional, leave blank to use official defaults) ---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- Model Selection ---
CLAUDE_MODEL=claude-4.6-sonnet
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=1024      # Max tokens per response
MODEL_TEMPERATURE=0.7             # Creativity 0.0~1.0
MODEL_CALL_RETRIES=3              # API retry attempts on failure
MODEL_BACKOFF_BASE=2              # Retry backoff base (seconds)

# --- Debate Settings ---
DEBATE_DEFAULT_ROUNDS=3           # Default rounds (overridden by --rounds)
DEBATE_INTERACTIVE=true           # Ask to continue after planned rounds (--no-interactive to disable)
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=12000    # Max history chars injected into prompts
DEBATE_OPENING_DIGEST_CHARS=200   # Opening digest length
DEBATE_SUMMARY_DIGEST_CHARS=150   # Earlier-round digest length
DEBATE_FULL_DETAIL_ROUNDS=2       # Number of recent rounds shown in full
CHAIR_SUMMARY_SUP_CHARS=600       # Supporters speech truncation in chair summary
CHAIR_SUMMARY_OPP_CHARS=600       # Opponents speech truncation in chair summary
CHAIR_SUMMARY_SPECIALIST_CHARS=400 # Specialist speech truncation in chair summary
CHAIR_SUMMARY_DIGEST_CHARS=150    # Past chair summary digest length

# --- Output ---
DEBATE_FILENAME_TOPIC_CHARS=30    # Max topic chars in output filename
