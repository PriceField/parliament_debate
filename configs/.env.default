# ══════════════════════════════════════════════════════════════
#  ⚖️  Default — 標準平衡模式
#  Standard balanced configuration, same as built-in defaults.
#  適合：一般使用、首次嘗試
# ══════════════════════════════════════════════════════════════

# --- API Keys（必填 / Required）---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints（選填 / Optional，留空使用官方預設）---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- 模型選擇 / Model Selection ---
CLAUDE_MODEL=claude-4.6-sonnet
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- 模型行為 / Model Behaviour ---
MODEL_MAX_OUTPUT_TOKENS=1024      # 每次回覆的最大 token 數
MODEL_TEMPERATURE=0.7             # 創意程度 0.0~1.0
MODEL_CALL_RETRIES=3              # API 失敗重試次數
MODEL_BACKOFF_BASE=2              # 重試間隔基數（秒）

# --- 辯論設定 / Debate Settings ---
DEBATE_DEFAULT_ROUNDS=3           # 預設輪數（可被 --rounds 覆蓋）
DEBATE_CHECKPOINT_DB=debate_checkpoints.db

# --- 上下文截斷 / Context Truncation ---
DEBATE_MAX_HISTORY_CHARS=12000    # 注入提示的歷史上限字元數
DEBATE_OPENING_DIGEST_CHARS=200   # 開場摘要長度
DEBATE_SUMMARY_DIGEST_CHARS=150   # 早期輪次摘要長度
DEBATE_FULL_DETAIL_ROUNDS=2       # 完整顯示的最近輪數
CHAIR_SUMMARY_SUP_CHARS=600       # 主席總結中支持派截斷
CHAIR_SUMMARY_OPP_CHARS=600       # 主席總結中反對派截斷
CHAIR_SUMMARY_SPECIALIST_CHARS=400 # 主席總結中專家截斷
CHAIR_SUMMARY_DIGEST_CHARS=150    # 歷屆主席總結摘要長度

# --- 輸出 / Output ---
DEBATE_FILENAME_TOPIC_CHARS=30    # 檔名中議題的最大字元數
