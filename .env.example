# ══════════════════════════════════════
#  Parliament Debate — 基本設定
# ══════════════════════════════════════

# --- API Keys（必填）---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
XAI_API_KEY=xai-...

# --- API Endpoints（選填，留空使用官方預設）---
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GOOGLE_BASE_URL=
XAI_BASE_URL=

# --- 模型選擇 ---
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
GOOGLE_MODEL=gemini-3-flash-preview
GROK_MODEL=grok-3-mini

# --- 常用調整 ---
# 每次回覆的最大 token 數（越大回覆越長，也越貴）
MODEL_MAX_OUTPUT_TOKENS=1024

# 創意程度 0.0~1.0（越高越發散）
MODEL_TEMPERATURE=0.7

# 預設辯論輪數（可被 --rounds 覆蓋）
DEBATE_DEFAULT_ROUNDS=3

# ══════════════════════════════════════
#  更多模板請見 configs/ 目錄
#  複製模板: cp configs/.env.token-saver .env
# ══════════════════════════════════════
